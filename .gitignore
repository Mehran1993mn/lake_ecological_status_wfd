# Raw large data
inputs/raw_data/*
!inputs/raw_data/.gitkeep

# Outputs
outputs/*
!outputs/.gitkeep

# Large generated files
*.xlsx
*.xls
*.zip
*.pkl
*.joblib

# Do not ignore small required CSV/TXT unless intentionally added
# *.csv

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Environments
.venv/
env/
.DS_Store
